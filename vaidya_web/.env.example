# Vaidya-AI Web — Environment Variables

# Supabase (same project as pipeline + MCP)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# MCP Server (local path to vaidya_mcp/server.py)
MCP_SERVER_PATH=/absolute/path/to/vaidya_mcp/server.py

# Business config (same as MCP)
BUSINESS_NAME=Magadh Wellness Private Limited
OWNER_NAME=Papa
